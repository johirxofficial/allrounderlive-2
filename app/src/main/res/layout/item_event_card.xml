<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginTop="10dp"
    app:cardBackgroundColor="@color/colorSurface"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_badge_live"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="LIVE"
            xmlns:tools="http://schemas.android.com/tools" />

        <TextView
            android:id="@+id/tvEventTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/tvStatusBadge"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/colorOnSurface"
            android:textSize="16sp"
            tools:text="ICC Men's T20 World Cup"
            xmlns:tools="http://schemas.android.com/tools" />

        <TextView
            android:id="@+id/tvEventDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvEventTitle"
            android:layout_toStartOf="@id/tvStatusBadge"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/colorOnSurfaceMuted"
            android:textSize="12sp"
            tools:text="Grand Finale - Match Live from Stadium"
            xmlns:tools="http://schemas.android.com/tools" />

        <!-- VS Layout -->
        <LinearLayout
            android:id="@+id/vsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvEventDescription"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgTeamOne"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/team_logo_desc"
                    android:src="@drawable/circle_placeholder" />

                <TextView
                    android:id="@+id/tvTeamOneName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="13sp"
                    tools:text="Bangladesh"
                    xmlns:tools="http://schemas.android.com/tools" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:paddingHorizontal="10dp"
                android:text="@string/vs_label"
                android:textColor="@color/colorAccent"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgTeamTwo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="@string/team_logo_desc"
                    android:src="@drawable/circle_placeholder" />

                <TextView
                    android:id="@+id/tvTeamTwoName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="@color/colorOnSurface"
                    android:textSize="13sp"
                    tools:text="India"
                    xmlns:tools="http://schemas.android.com/tools" />
            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>
