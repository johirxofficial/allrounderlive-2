<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgSheetLogo"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:contentDescription="@string/app_logo_desc"
            android:src="@drawable/circle_placeholder" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSheetAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/colorOnSurface"
                android:textSize="18sp"
                tools:text="SportsLive HQ"
                xmlns:tools="http://schemas.android.com/tools" />

            <TextView
                android:id="@+id/tvSheetVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/colorOnSurfaceMuted"
                android:textSize="12sp"
                tools:text="Version 1.0.4"
                xmlns:tools="http://schemas.android.com/tools" />

            <TextView
                android:id="@+id/tvSheetDeveloper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/colorOnSurfaceMuted"
                android:textSize="12sp"
                tools:text="Developed by johirxofficial"
                xmlns:tools="http://schemas.android.com/tools" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvSheetAbout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/colorOnSurface"
        android:textSize="14sp"
        tools:text="Welcome to SportsLive HQ..."
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif-medium"
        android:text="@string/follow_us"
        android:textColor="@color/colorOnSurface"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnFacebook"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_card_rounded"
            android:contentDescription="@string/facebook_desc"
            android:padding="10dp"
            android:src="@drawable/ic_facebook" />

        <ImageButton
            android:id="@+id/btnTelegram"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_card_rounded"
            android:contentDescription="@string/telegram_desc"
            android:padding="10dp"
            android:src="@drawable/ic_telegram" />

        <ImageButton
            android:id="@+id/btnYoutube"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_card_rounded"
            android:contentDescription="@string/youtube_desc"
            android:padding="10dp"
            android:src="@drawable/ic_youtube" />
    </LinearLayout>

</LinearLayout>
